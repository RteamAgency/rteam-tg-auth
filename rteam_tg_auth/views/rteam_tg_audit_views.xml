<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_rteam_tg_audit_list" model="ir.ui.view">
        <field name="name">rteam.tg.audit.list</field>
        <field name="model">rteam.tg.audit</field>
        <field name="arch" type="xml">
            <list string="Telegram 2FA Audit Log" create="false" edit="false" delete="false">
                <field name="create_date" string="When"/>
                <field name="user_id"/>
                <field name="event" widget="badge"/>
                <field name="ip"/>
                <field name="tg_message_id"/>
                <field name="note" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_rteam_tg_audit_search" model="ir.ui.view">
        <field name="name">rteam.tg.audit.search</field>
        <field name="model">rteam.tg.audit</field>
        <field name="arch" type="xml">
            <search string="Audit Log">
                <field name="user_id"/>
                <field name="event"/>
                <field name="ip"/>
                <filter name="rejected" string="Rejected challenges" domain="[('event','=','challenge_rejected')]"/>
                <filter name="rate_limited" string="Rate limited" domain="[('event','=','rate_limited')]"/>
                <group>
                    <filter name="group_user" string="User" context="{'group_by':'user_id'}"/>
                    <filter name="group_event" string="Event" context="{'group_by':'event'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_rteam_tg_audit" model="ir.actions.act_window">
        <field name="name">Telegram 2FA Audit Log</field>
        <field name="res_model">rteam.tg.audit</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
