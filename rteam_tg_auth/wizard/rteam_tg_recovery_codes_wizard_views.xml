<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_rteam_tg_recovery_codes_wizard_form" model="ir.ui.view">
        <field name="name">rteam.tg.recovery.codes.wizard.form</field>
        <field name="model">rteam.tg.recovery.codes.wizard</field>
        <field name="arch" type="xml">
            <form string="Recovery Codes">
                <sheet>
                    <div class="oe_title">
                        <h2>Save these recovery codes now</h2>
                        <p>
                            Each code is single-use. Use one to log in if you
                            lose access to your Telegram chat. They are
                            shown <strong>only once</strong>; you can
                            generate a fresh set from your profile, but
                            doing so invalidates the current set.
                        </p>
                    </div>
                    <field name="user_id" invisible="1"/>
                    <field name="binding_id" invisible="1"/>
                    <field name="codes_text" widget="text" readonly="1" nolabel="1"
                           class="oe_inline" style="font-family: monospace; font-size: 14px;"/>
                    <div class="alert alert-warning mt-3" role="alert">
                        Treat these as you would a password. Anyone who has
                        a code AND knows your Odoo password can log into
                        this account.
                    </div>
                    <group>
                        <field name="saved_confirm"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_close"
                            type="object"
                            string="Done"
                            class="btn-primary"
                            invisible="not saved_confirm"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
