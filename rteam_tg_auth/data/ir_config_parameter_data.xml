<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="param_enforce_2fa" model="ir.config_parameter">
            <field name="key">rteam_tg_auth.enforce_2fa</field>
            <field name="value">False</field>
        </record>

        <record id="param_bind_token_ttl_seconds" model="ir.config_parameter">
            <field name="key">rteam_tg_auth.bind_token_ttl_seconds</field>
            <field name="value">600</field>
        </record>

        <record id="param_code_ttl_seconds" model="ir.config_parameter">
            <field name="key">rteam_tg_auth.code_ttl_seconds</field>
            <field name="value">300</field>
        </record>

        <record id="param_code_attempt_limit" model="ir.config_parameter">
            <field name="key">rteam_tg_auth.code_attempt_limit</field>
            <field name="value">5</field>
        </record>

        <record id="param_rate_limit_window_seconds" model="ir.config_parameter">
            <field name="key">rteam_tg_auth.rate_limit_window_seconds</field>
            <field name="value">900</field>
        </record>

        <record id="param_rate_limit_max" model="ir.config_parameter">
            <field name="key">rteam_tg_auth.rate_limit_max</field>
            <field name="value">5</field>
        </record>

    </data>
</odoo>
